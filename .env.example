# Server Configuration
PORT=3000
NODE_ENV=development

# OpenCode Server Configuration
OPENCODE_SERVER_PORT=4096

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds

# Temporary File Management
TEMP_MAX_AGE=86400000     # 24 hours in milliseconds
TEMP_CLEANUP_INTERVAL=3600000  # 1 hour in milliseconds

# OpenCode API Configuration (if using direct API)
# OPENCODE_API_KEY=your_opencode_api_key_here
# OPENCODE_BASE_URL=http://localhost:4096

# Note: The system expects opencode CLI to be installed globally
# Run: npm install -g opencode-ai or use the installation script